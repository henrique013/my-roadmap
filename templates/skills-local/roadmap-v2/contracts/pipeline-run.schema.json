{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sha256"
        }
      },
      "required": [
        "path"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "PipeResult": {
      "additionalProperties": false,
      "properties": {
        "attempts": {
          "default": 1,
          "minimum": 0,
          "title": "Attempts",
          "type": "integer"
        },
        "duration_ms": {
          "default": 0,
          "minimum": 0,
          "title": "Duration Ms",
          "type": "integer"
        },
        "error_message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error Message"
        },
        "error_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error Type"
        },
        "input_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Input Hash"
        },
        "output_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Output Hash"
        },
        "pipe_id": {
          "minLength": 1,
          "title": "Pipe Id",
          "type": "string"
        },
        "read_artifacts": {
          "items": {
            "$ref": "#/$defs/ArtifactRef"
          },
          "title": "Read Artifacts",
          "type": "array"
        },
        "status": {
          "enum": [
            "pending",
            "success",
            "failed",
            "skipped"
          ],
          "title": "Status",
          "type": "string"
        },
        "written_artifacts": {
          "items": {
            "$ref": "#/$defs/ArtifactRef"
          },
          "title": "Written Artifacts",
          "type": "array"
        }
      },
      "required": [
        "pipe_id",
        "status"
      ],
      "title": "PipeResult",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "finished_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Finished At"
    },
    "mode": {
      "enum": [
        "roadmap-v2-page",
        "roadmap-v2-node-page"
      ],
      "title": "Mode",
      "type": "string"
    },
    "output_root": {
      "minLength": 1,
      "title": "Output Root",
      "type": "string"
    },
    "pipe_results": {
      "items": {
        "$ref": "#/$defs/PipeResult"
      },
      "title": "Pipe Results",
      "type": "array"
    },
    "run_id": {
      "minLength": 1,
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "roadmap-v2.0",
      "title": "Schema Version",
      "type": "string"
    },
    "started_at": {
      "minLength": 1,
      "title": "Started At",
      "type": "string"
    },
    "status": {
      "enum": [
        "success",
        "failed"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "required": [
    "run_id",
    "mode",
    "status",
    "output_root",
    "started_at"
  ],
  "title": "PipelineRun",
  "type": "object"
}
