---
import { readFileSync } from 'node:fs';
import BlockRenderer from '../components/BlockRenderer.astro';
import NodeLayout from '../layouts/NodeLayout.astro';
import RoadmapLayout from '../layouts/RoadmapLayout.astro';
import type { PageSpec } from '../lib/page-spec';

const pageSpecPath = process.env.PAGE_SPEC_PATH;
if (!pageSpecPath) {
  throw new Error('PAGE_SPEC_PATH is required');
}

const spec = JSON.parse(readFileSync(pageSpecPath, 'utf-8')) as PageSpec;
const Layout = spec.page_type === 'node' ? NodeLayout : RoadmapLayout;
---
<Layout spec={spec}>
  {spec.blocks.map((block) => <BlockRenderer block={block} />)}
</Layout>
