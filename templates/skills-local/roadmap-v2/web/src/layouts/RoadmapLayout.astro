---
import '../styles/roadmap.css';
import type { PageSpec } from '../lib/page-spec';

interface Props {
  spec: PageSpec;
}

const { spec } = Astro.props;
---
<!doctype html>
<html lang="pt-BR" class="wa-theme-default">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={spec.description} />
    <title>{spec.title}</title>
    <link rel="stylesheet" href="vendor/webawesome/dist-cdn/styles/webawesome.css" />
    <script type="module" src="vendor/webawesome/dist-cdn/webawesome.loader.js"></script>
  </head>
  <body>
    <div class="page-shell" data-page-type={spec.page_type}>
      <header class="page-header">
        <div class="page-header__inner">
          <strong>{spec.title}</strong>
          <wa-badge>{spec.page_type}</wa-badge>
        </div>
      </header>
      <main class="page-main">
        <slot />
      </main>
    </div>
  </body>
</html>
