{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "roadmap-contract.schema.json",
  "title": "Roadmap Contract",
  "type": "object",
  "required": [
    "schema_version",
    "roadmap_slug",
    "theme",
    "sources",
    "anti_repetition",
    "nodes"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "roadmap_slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "theme": {
      "type": "string",
      "minLength": 1
    },
    "background": {
      "type": "string"
    },
    "research_date": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_understanding": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "url",
          "reason"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^F[0-9]+$"
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "supports_nodes": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[0-9]{2}-[a-z0-9][a-z0-9-]*$"
            }
          },
          "limits": {
            "type": "string"
          }
        }
      }
    },
    "anti_repetition": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "concept",
          "first_introduction_node",
          "allowed_reuses",
          "blocked_reuses",
          "boundary_reason"
        ],
        "properties": {
          "concept": {
            "type": "string",
            "minLength": 1
          },
          "first_introduction_node": {
            "type": "string",
            "pattern": "^[0-9]{2}-[a-z0-9][a-z0-9-]*$"
          },
          "allowed_reuses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocked_reuses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "boundary_reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "order",
          "slug",
          "label",
          "role_in_chain",
          "must_cover",
          "must_not_cover",
          "questions",
          "references"
        ],
        "properties": {
          "order": {
            "type": "integer"
          },
          "slug": {
            "type": "string",
            "pattern": "^[0-9]{2}-[a-z0-9][a-z0-9-]*$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "role_in_chain": {
            "type": "string",
            "minLength": 1
          },
          "inherited_prerequisites": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "first_introduces": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "must_cover": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "must_not_cover": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "questions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "conceptual_vocabulary": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allowed_examples_or_diagrams": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "pitfalls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "mastery_criterion": {
            "type": "string"
          },
          "handoff_to_next": {
            "type": "string"
          },
          "references": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "source_id",
                "url",
                "reason"
              ],
              "properties": {
                "source_id": {
                  "type": "string",
                  "pattern": "^F[0-9]+$"
                },
                "url": {
                  "type": "string",
                  "minLength": 1
                },
                "reason": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
