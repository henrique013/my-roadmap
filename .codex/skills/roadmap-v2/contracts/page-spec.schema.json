{
  "$defs": {
    "NavigationLink": {
      "additionalProperties": false,
      "properties": {
        "href": {
          "minLength": 1,
          "title": "Href",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "rel": {
          "default": "node",
          "enum": [
            "self",
            "parent",
            "previous",
            "next",
            "node",
            "source"
          ],
          "title": "Rel",
          "type": "string"
        }
      },
      "required": [
        "label",
        "href"
      ],
      "title": "NavigationLink",
      "type": "object"
    },
    "PageBlock": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "items": {
          "items": {
            "additionalProperties": true,
            "type": "object"
          },
          "title": "Items",
          "type": "array"
        },
        "props": {
          "additionalProperties": true,
          "title": "Props",
          "type": "object"
        },
        "text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Text"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Title"
        },
        "type": {
          "enum": [
            "hero",
            "level_tabs",
            "node_grid",
            "concept_section",
            "source_list",
            "navigation_trail",
            "references"
          ],
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "id",
        "type"
      ],
      "title": "PageBlock",
      "type": "object"
    },
    "Source": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "source_type": {
          "enum": [
            "official-docs",
            "source-code",
            "standard",
            "article",
            "paper",
            "book",
            "other"
          ],
          "title": "Source Type",
          "type": "string"
        },
        "supports": {
          "items": {
            "type": "string"
          },
          "title": "Supports",
          "type": "array"
        },
        "title": {
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "url": {
          "format": "uri",
          "minLength": 1,
          "title": "Url",
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "url",
        "source_type",
        "reason"
      ],
      "title": "Source",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "blocks": {
      "items": {
        "$ref": "#/$defs/PageBlock"
      },
      "minItems": 1,
      "title": "Blocks",
      "type": "array"
    },
    "description": {
      "minLength": 1,
      "title": "Description",
      "type": "string"
    },
    "navigation": {
      "items": {
        "$ref": "#/$defs/NavigationLink"
      },
      "title": "Navigation",
      "type": "array"
    },
    "page_type": {
      "enum": [
        "roadmap",
        "node"
      ],
      "title": "Page Type",
      "type": "string"
    },
    "schema_version": {
      "default": "roadmap-v2.0",
      "title": "Schema Version",
      "type": "string"
    },
    "slug": {
      "minLength": 1,
      "title": "Slug",
      "type": "string"
    },
    "sources": {
      "items": {
        "$ref": "#/$defs/Source"
      },
      "title": "Sources",
      "type": "array"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    }
  },
  "required": [
    "page_type",
    "title",
    "slug",
    "description",
    "blocks"
  ],
  "title": "PageSpec",
  "type": "object"
}
